<launch>
    <arg name="timeout_sec" default="0.05"/>
    <arg name="cutted_input_topic" default="/luminar_pcl"/>
    <arg name="cutted_output_topic" default="/luminar_pcl_cutted"/>
    <arg name="cut_angle_right_deg" default="0.0"/>
    <arg name="cut_angle_left_deg" default="0.0"/>
    <arg name="min_distance_x" default="0.0"/>
    <arg name="use_reliable_qos" default="true"/>
    <arg name="point_cloud_frame_id" default="luminar_lidar_0"/>
    <arg name="camera_topics"
         default="[/sensing/camera/camera0/, /sensing/camera/camera1/]"/>
    <arg name="image_type" default="0" description="0:RAW, 1:RECTIFIED"/>
    <arg name="use_compressed_image" default="false"/>
    <arg name="image_topic_last_name" default="image_rect_color"/>
    <arg name="camera_info_topic_last_name" default="camera_info"/>
    <arg name="debug" default="false"/>

    <node pkg="color_point_cloud" exec="cutted_pointcloud" name="cutted_pointcloud" output="screen">
        <param name="use_sim_time" value="true"/>
        <param name="input_topic" value="$(var cutted_input_topic)"/>
        <param name="output_topic" value="$(var cutted_output_topic)"/>
        <param name="cut_angle_right_deg" value="$(var cut_angle_right_deg)"/>
        <param name="cut_angle_left_deg" value="$(var cut_angle_left_deg)"/>
        <param name="min_distance_x" value="$(var min_distance_x)"/>
        <param name="use_reliable_qos" value="$(var use_reliable_qos)"/>
        <param name="debug" value="$(var debug)"/>
    </node>

    <node pkg="color_point_cloud" exec="color_point_cloud" name="color_point_cloud" output="screen">
        <param name="use_sim_time" value="true"/>
        <param name="timeout_sec" value="$(var timeout_sec)"/>
        <param name="point_cloud_topic" value="$(var cutted_output_topic)"/>
        <param name="point_cloud_frame_id" value="$(var point_cloud_frame_id)"/>
        <param name="camera_topics" value="$(var camera_topics)"/>
        <param name="image_type" value="$(var image_type)"/>
        <param name="use_compressed_image" value="$(var use_compressed_image)"/>
        <param name="use_reliable_qos" value="$(var use_reliable_qos)"/>
        <param name="image_topic_last_name" value="$(var image_topic_last_name)"/>
        <param name="camera_info_topic_last_name" value="$(var camera_info_topic_last_name)"/>
        <param name="debug" value="$(var debug)"/>
    </node>
</launch>
